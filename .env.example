# Mapper Copilot Configuration

# Provider selection: mock | bedrock | local
# - mock: Offline, deterministic (HashingEmbedder + MockLLM) for testing
# - bedrock: AWS Bedrock API (requires boto3 and AWS credentials)
# - local: Local sentence-transformers models (requires pip install 'mapper-copilot[local-embeddings]')
PROVIDER=mock

# AWS Bedrock Configuration (only used if PROVIDER=bedrock)
AWS_REGION=us-west-2
AWS_PROFILE=default
# If using assume-role via corporate gateway:
# AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/ROLE_NAME

# Embedding Model Configuration
# For PROVIDER=bedrock: Use Bedrock model ID (e.g., amazon.titan-embed-text-v2:0)
# For PROVIDER=local: Use HuggingFace model name (e.g., all-MiniLM-L6-v2, all-mpnet-base-v2)
# For PROVIDER=mock: This field is ignored
EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Embedding dimension (used for mock provider, auto-detected for others)
EMBEDDING_DIMENSION=512

# Local Provider Example:
# PROVIDER=local
# EMBEDDING_MODEL_ID=all-MiniLM-L6-v2  # 384-dim, 120MB, fast
# EMBEDDING_DIMENSION=384
#
# Alternative local models:
# EMBEDDING_MODEL_ID=all-mpnet-base-v2  # 768-dim, 420MB, better quality

# LLM Model Configuration (Bedrock)
LLM_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# Vector Retrieval Configuration
VECTOR_STORE_TYPE=numpy  # numpy | faiss | pgvector
RETRIEVE_TOP_K=10
RETRIEVE_THRESHOLD=0.5

# Hybrid Retrieval Configuration
# Hybrid retrieval combines dense embeddings (semantic) with BM25 (lexical/keyword matching)
K_RETRIEVE=40            # Number of candidates to retrieve from hybrid search (default 40)
USE_BM25=true            # Enable BM25 lexical retrieval (helps with numbers, codes, exact terms)
SECTION_PRIOR_WEIGHT=0.1 # Soft boost for same-section candidates (0.0-1.0, default 0.1)

# Optional Reranker (refines top-K candidates from retrieval)
# - none: No reranking, use hybrid retrieval scores directly
# - local: Cross-encoder reranker (offline, requires pip install 'mapper-copilot[local-embeddings]')
# - llm: Anthropic Claude API reranker (requires ANTHROPIC_API_KEY)
RERANKER=none            # none | local | llm
RERANKER_MODEL=claude-sonnet-4-6   # For llm: claude model | For local: ignored (uses CROSS_ENCODER_MODEL)
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2  # For RERANKER=local
ANTHROPIC_API_KEY=       # Required only when RERANKER=llm

# Example: Full offline setup (local embeddings + BM25 + cross-encoder reranking)
# PROVIDER=local
# EMBEDDING_MODEL_ID=all-MiniLM-L6-v2
# RERANKER=local
# CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
#
# Example: Hybrid local + Claude reranker (local retrieval, API for final ranking)
# PROVIDER=local
# EMBEDDING_MODEL_ID=all-MiniLM-L6-v2
# RERANKER=llm
# RERANKER_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Data paths
SLCP_QUESTIONS_FILE=data/slcp_questions.xlsx
RSC_QUESTIONS_FILE=data/rsc_questions.xlsx
GROUND_TRUTH_MAPPING=data/mapper_data.json

# Logging
LOG_LEVEL=INFO
